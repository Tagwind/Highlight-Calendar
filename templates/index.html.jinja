<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Highlight Calendar</title>

    <!-- Global theme tokens -->
    <link rel="stylesheet" href="{{ url_for('static', filename='css/hl-theme.css') }}">

    <style>
        *,
        *::before,
        *::after {
            box-sizing: border-box;
        }

        html,
        body {
            height: 100%;
            margin: 0;
        }

        body {
            display: flex;
            font-family: sans-serif;
            background: var(--bg-app);
            color: var(--text-primary);
        }

        .sidebar {
            width: 250px;
            background: var(--bg-surface);
            display: flex;
            flex-direction: column;
            padding: 20px;
            border-right: 1px solid var(--border-subtle);
        }

        .sidebar button {
            background: none;
            border: none;
            color: var(--text-secondary);
            padding: 15px;
            text-align: left;
            font-size: 1.1rem;
            cursor: pointer;
        }

        .sidebar button.active {
            color: var(--accent);
            font-weight: bold;
        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            /* important */
            padding: 30px;
        }

        .view-container {
            display: flex;
            flex: 1;
            min-height: 0;
        }

        .view-content {
            display: flex;
            flex: 1;
        }

        .calendar-component {
            display: flex;
            flex-direction: column;
            flex: 1;
        }
    </style>

    <!-- Load components ONCE -->
    <script type="module" src="{{ url_for('static', filename='js/components/views/calendar/calendar.js') }}"></script>
    <script type="module" src="{{ url_for('static', filename='js/components/basic/card/card.js') }}"></script>
    <script type="module"
        src="{{ url_for('static', filename='js/components/complex/calendarday/calendarday.js') }}"></script>
    <script type="module"
        src="{{ url_for('static', filename='js/components/complex/header-bar/header-bar.js') }}"></script>

    <!-- App controller -->
    <script type="module" src="{{ url_for('static', filename='js/main.js') }}"></script>
</head>

<body>
    <div class="sidebar">
        <button onclick="nav('calendar', this)">Calendar</button>
        <button onclick="nav('rewards', this)">Rewards</button>
        <button onclick="nav('settings', this)">Settings</button>
    </div>


    <div id="app-view" class="main-content">
        <div class="header-bar">
            <hl-header-bar></hl-header-bar>
        </div>

        <!-- This area is dynamic and changing -->
        <div class="view-container">
            <div id="view-content-id" class="view-content">
                <hl-calendar class="calendar-component"></hl-calendar>
            </div>
        </div>
    </div>
</body>

</html>